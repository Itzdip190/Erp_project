# Block access to sensitive files and directories
<FilesMatch "^\.env|^\.git|composer\.(json|lock)|package\.(json|lock)|artisan|phpunit\.xml">
    Order allow,deny
    Deny from all
</FilesMatch>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Don't rewrite if the target file/directory already exists
    # (prevents infinite loop: uploads/x → public/uploads/x → public/public/uploads/x ...)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Redirect all other traffic to the public directory
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
