# Block access to sensitive files and directories
<FilesMatch "^\.env|^\.git|composer\.(json|lock)|package\.(json|lock)|artisan|phpunit\.xml">
    Order allow,deny
    Deny from all
</FilesMatch>

<IfModule mod_rewrite.c>
    RewriteEngine On
    # Redirect all traffic to the public directory
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
